# ==========================================
# ThreatRadar Environment Variables Template
# ==========================================
# Usage: Copy this file to '.env' and replace the placeholder values.
# DO NOT commit the actual '.env' file to version control.

# GitHub API Configuration (for dependency scanning)
# Used by: github_scanner module
GITHUB_TOKEN=your_github_personal_access_token_here

# NVD API Configuration (for vulnerability feeds)
# Used by: crawler module
NVD_API_KEY=your_nvd_api_key_here